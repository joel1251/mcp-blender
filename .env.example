# Environment variables for Blender MCP
# Copy this file to .env and fill in actual values (do NOT commit .env to Git)

# Anthropic API key — required only for the "IA" mode of the web panel's
# natural-language input (web/server.mjs). Get one at https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# Telemetry (optional)
# DISABLE_TELEMETRY=false
# SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_BUCKET=telemetry
# TELEMETRY_TIMEOUT=10

# Sketchfab API
# BLENDERMCP_SKETCHFAB_API_KEY=your_sketchfab_api_key

# Hyper3D API (free trial uses "vibecoding")
# BLENDERMCP_HYPER3D_API_KEY=your_hyper3d_api_key

# Hunyuan3D API (Tencent Cloud)
# BLENDERMCP_HUNYUAN3D_SECRET_ID=your_secret_id
# BLENDERMCP_HUNYUAN3D_SECRET_KEY=your_secret_key
# BLENDERMCP_HUNYUAN3D_API_URL=http://localhost:8081
